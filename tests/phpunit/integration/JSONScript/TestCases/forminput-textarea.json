{
	"description": "form input textarea",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "Text Property",
			"contents": "[[Has type::Text]]"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Textarea input without other parameters",
			"contents": "{{{field|Textarea|input type=textarea}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Textarea input with rows param",
			"contents": "{{{field|Textarea|input type=textarea|rows=10}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Textarea input with cols param",
			"contents": "{{{field|Textarea|input type=textarea|cols=50}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Textarea input with placeholder param",
			"contents": "{{{field|Textarea|input type=textarea|placeholder=add text here}}}"
		},
		{
			"namespace": "NS_TEMPLATE",
			"page": "PFTestTAPreloadTpl01",
			"contents": "{{{PFTAPreloadField01|}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "PFTestTAFormPreload01",
			"contents": "{{{for template|PFTestTAPreloadTpl01}}}\n{{{field|PFTAPreloadField01|input type=textarea}}}\n{{{end template}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "PFTestTAFormAutogrow01",
			"contents": "{{{for template|PFTestTAPreloadTpl01}}}\n{{{field|PFTAPreloadField01|input type=textarea|autogrow}}}\n{{{end template}}}"
		},
		{
			"page": "PFTestTASubjPreload01",
			"contents": "{{PFTestTAPreloadTpl01|PFTAPreloadField01=PFTAStoredContent01}}"
		}
	],
	"tests": [
		{
			"type": "special",
			"about": "Textarea input without other parameters",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "Textarea input without other parameters/01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"<textarea tabindex=\"1\" name=\"standard input[Textarea]\" id=\"input_1\" class=\"createboxInput\" rows=\"5\" cols=\"90\" style=\"width: 100%\"></textarea>"
				]
			}
		},
		{
			"type": "special",
			"about": "Textarea input with rows param",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "Textarea input with rows param/01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"<textarea tabindex=\"1\" name=\"standard input[Textarea]\" id=\"input_1\" class=\"createboxInput\" rows=\"10\" cols=\"90\" style=\"width: 100%\"></textarea>"
				]
			}
		},
		{
			"type": "special",
			"about": "Textarea input with cols param",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "Textarea input with cols param/01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"cols=\"50\""
				],
				"not-contain": [
					"cols=\"90\""
				]
			}
		},
		{
			"type": "special",
			"about": "Textarea input with placeholder param",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "Textarea input with placeholder param/01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"<textarea tabindex=\"1\" name=\"standard input[Textarea]\" id=\"input_1\" class=\"createboxInput\" rows=\"5\" cols=\"90\" style=\"width: 100%\" placeholder=\"add text here\">"
				]
			}
		},
		{
			"type": "special",
			"about": "textarea preload: stored value appears as textarea content on re-edit",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "PFTestTAFormPreload01/PFTestTASubjPreload01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"PFTAStoredContent01"
				]
			}
		},
		{
			"type": "special",
			"about": "textarea autogrow: autoGrow class is added when autogrow param is set",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "PFTestTAFormAutogrow01/PFTestTANewPage01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"autoGrow"
				]
			}
		}
	],
	"settings": {
		"wgLang": "en"
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
