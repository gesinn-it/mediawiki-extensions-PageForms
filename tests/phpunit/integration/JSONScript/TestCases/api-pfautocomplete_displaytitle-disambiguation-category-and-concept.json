{
	"description": "Test API `action=pfautocomplete` disambiguates duplicate display titles for category and concept search",
	"setup": [
		{
			"page": "PFTestDDAlpha01",
			"contents": "[[Category:PFTestDDCat01]]{{DISPLAYTITLE:Paris}}"
		},
		{
			"page": "PFTestDDBeta01",
			"contents": "[[Category:PFTestDDCat01]]{{DISPLAYTITLE:Paris}}"
		},
		{
			"namespace": "SMW_NS_CONCEPT",
			"page": "PFTestDDConcept01",
			"contents": "{{#concept: [[Category:PFTestDDCat01]]}}"
		}
	],
	"tests": [
		{
			"type": "api",
			"about": "category search disambiguates duplicate display titles",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"category": "PFTestDDCat01",
					"substr": "Par"
				}
			},
			"assert-output": {
				"to-contain": "{\"pfautocomplete\":{\"0\":{\"title\":\"PFTestDDAlpha01\",\"displaytitle\":\"Paris (PFTestDDAlpha01)\"},\"1\":{\"title\":\"PFTestDDBeta01\",\"displaytitle\":\"Paris (PFTestDDBeta01)\"},\"_element\":\"p\"},\"_type\":\"assoc\"}"
			}
		},
		{
			"type": "api",
			"about": "concept search disambiguates duplicate display titles",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"concept": "PFTestDDConcept01",
					"substr": "Par"
				}
			},
			"assert-output": {
				"to-contain": "{\"pfautocomplete\":{\"0\":{\"title\":\"PFTestDDAlpha01\",\"displaytitle\":\"Paris (PFTestDDAlpha01)\"},\"1\":{\"title\":\"PFTestDDBeta01\",\"displaytitle\":\"Paris (PFTestDDBeta01)\"},\"_element\":\"p\"},\"_type\":\"assoc\"}"
			}
		}
	],
	"settings": {
		"wgAllowDisplayTitle": true,
		"wgRestrictDisplayTitle": false,
		"smwgNamespacesWithSemanticLinks": {
			"NS_MAIN": true,
			"SMW_NS_CONCEPT": true
		}
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
