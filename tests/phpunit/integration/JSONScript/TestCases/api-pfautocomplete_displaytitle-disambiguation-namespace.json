{
	"description": "Test API `action=pfautocomplete` disambiguates duplicate display titles for namespace search",
	"setup": [
		{
			"page": "PFTestDDAlpha01",
			"contents": "[[Category:PFTestDDCat01]]{{DISPLAYTITLE:Paris}}"
		},
		{
			"page": "PFTestDDBeta01",
			"contents": "[[Category:PFTestDDCat01]]{{DISPLAYTITLE:Paris}}"
		}
	],
	"tests": [
		{
			"type": "api",
			"about": "namespace search disambiguates duplicate display titles",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"namespace": "",
					"substr": "Par"
				}
			},
			"assert-output": {
				"to-contain": "{\"pfautocomplete\":{\"0\":{\"title\":\"PFTestDDAlpha01\",\"displaytitle\":\"Paris (PFTestDDAlpha01)\"},\"1\":{\"title\":\"PFTestDDBeta01\",\"displaytitle\":\"Paris (PFTestDDBeta01)\"},\"_element\":\"p\"},\"_type\":\"assoc\"}"
			}
		}
	],
	"settings": {
		"wgAllowDisplayTitle": true,
		"wgRestrictDisplayTitle": false,
		"smwgNamespacesWithSemanticLinks": {
			"NS_MAIN": true
		}
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
