{
	"description": "form input regexp",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "Text Property",
			"contents": "[[Has type::Text]]"
		},
		{
			"namespace": "NS_TEMPLATE",
			"page": "PFTestREXPTplReEdit01",
			"contents": "{{{PFREXPFieldReEdit01|}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "PFTestREXPFormReEdit01",
			"contents": "{{{for template|PFTestREXPTplReEdit01}}}\n{{{field|PFREXPFieldReEdit01|input type=regexp|regexp=/^[0-9A-Za-z ]+$/}}}\n{{{end template}}}"
		},
		{
			"page": "PFTestREXPSubjReEdit01",
			"contents": "{{PFTestREXPTplReEdit01|PFREXPFieldReEdit01=Hello World}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Regexp accepting only letters, numbers and spaces",
			"contents": "{{{field|Regexp|input type=regexp|regexp=/^[0-9A-Za-z ]+$/}}}"
		}
	],
	"tests": [
		{
			"type": "special",
			"about": "Regexp accepting only letters, numbers and spaces",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "Regexp accepting only letters, numbers and spaces/01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"createboxInput",
                    "standard input[Regexp]"
				]
			}
		},
		{
			"type": "special",
			"about": "Regexp re-edit: stored value pre-fills the base text input",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "PFTestREXPFormReEdit01/PFTestREXPSubjReEdit01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"value=\"Hello World\""
				]
			}
		}
	],
	"settings": {
		"wgLang": "en"
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
