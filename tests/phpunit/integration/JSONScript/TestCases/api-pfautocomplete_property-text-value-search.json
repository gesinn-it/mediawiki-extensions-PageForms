{
	"description": "Test API `action=pfautocomplete` property search returns text values filtered by substr",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "PFTestTextPropAC01",
			"contents": "[[Has type::Text]]"
		},
		{
			"page": "PFTestACTextPage01",
			"contents": "[[PFTestTextPropAC01::John Smith]]"
		},
		{
			"page": "PFTestACTextPage02",
			"contents": "[[PFTestTextPropAC01::Jane Doe]]"
		}
	],
	"tests": [
		{
			"type": "api",
			"about": "property text search returns values matching substr",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"property": "PFTestTextPropAC01",
					"substr": "John"
				}
			},
			"assert-output": {
				"to-contain": "\"title\":\"John Smith\""
			}
		},
		{
			"type": "api",
			"about": "property text search does not return values not matching substr",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"property": "PFTestTextPropAC01",
					"substr": "John"
				}
			},
			"assert-output": {
				"to-not-contain": "Jane Doe"
			}
		}
	],
	"beforeTest": {
		"job-run": [
			"smw.update"
		]
	},
	"settings": {
		"smwgNamespacesWithSemanticLinks": {
			"NS_MAIN": true,
			"SMW_NS_PROPERTY": true
		}
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
