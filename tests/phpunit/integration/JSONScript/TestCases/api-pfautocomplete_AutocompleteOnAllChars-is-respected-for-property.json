{
	"description": "Test API `action=pfautocomplete` wgPageFormsAutocompleteOnAllChars is respected for property search",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "PFTestAllCharsTextProp01",
			"contents": "[[Has type::Text]]"
		},
		{
			"page": "PFTestAllCharsTextPage01",
			"contents": "[[PFTestAllCharsTextProp01::FooBar]]"
		},
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "PFTestAllCharsPageProp01",
			"contents": "[[Has type::Page]]"
		},
		{
			"page": "PFTestAllCharsTarget FooBar",
			"contents": ""
		},
		{
			"page": "PFTestAllCharsPageSubjA",
			"contents": "[[PFTestAllCharsPageProp01::PFTestAllCharsTarget FooBar]]"
		}
	],
	"tests": [
		{
			"type": "api",
			"about": "text property search finds values matching in the middle of a word",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"property": "PFTestAllCharsTextProp01",
					"substr": "Bar"
				}
			},
			"assert-output": {
				"to-contain": "\"title\":\"FooBar\""
			}
		},
		{
			"type": "api",
			"about": "page-type property search finds values matching in the middle of a word",
			"api": {
				"parameters": {
					"action": "pfautocomplete",
					"format": "json",
					"property": "PFTestAllCharsPageProp01",
					"substr": "Bar"
				}
			},
			"assert-output": {
				"to-contain": "\"title\":\"PFTestAllCharsTarget FooBar\""
			}
		}
	],
	"settings": {
		"wgPageFormsAutocompleteOnAllChars": true,
		"smwgNamespacesWithSemanticLinks": {
			"NS_MAIN": true,
			"SMW_NS_PROPERTY": true
		}
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
