{
	"description": "form input checkbox",
	"setup": [
		{
			"namespace": "SMW_NS_PROPERTY",
			"page": "Boolean Property",
			"contents": "[[Has type::Boolean]]"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Checkbox without other parameters",
			"contents": "{{{field|Checkbox|input type=checkbox}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "Checkbox with parameter label",
			"contents": "{{{field|Checkbox|input type=checkbox|label=Test1}}}"
		},
		{
			"namespace": "NS_TEMPLATE",
			"page": "PFTestCBTplReEdit01",
			"contents": "{{{PFCBFieldReEdit01|}}}"
		},
		{
			"namespace": "PF_NS_FORM",
			"page": "PFTestCBFormReEdit01",
			"contents": "{{{for template|PFTestCBTplReEdit01}}}\n{{{field|PFCBFieldReEdit01|input type=checkbox}}}\n{{{end template}}}"
		},
		{
			"page": "PFTestCBSubjCheckedReEdit01",
			"contents": "{{PFTestCBTplReEdit01|PFCBFieldReEdit01=Yes}}"
		},
		{
			"page": "PFTestCBSubjUncheckedReEdit01",
			"contents": "{{PFTestCBTplReEdit01|PFCBFieldReEdit01=No}}"
		}
	],
	"tests": [
		{
			"type": "special",
			"about": "Checkbox without other parameters",
			"special-page": {
			"page": "FormEdit",
			"query-parameters": "Checkbox without other parameters/01",
			"request-parameters": {}
			},
			"assert-output": {
            "to-contain": [
                    "<input type='checkbox'",
                    "tabindex='1'",
                    "name='standard input[Checkbox][value]'",
                    "class='oo-ui-inputWidget-input' />",
					"standard input[Checkbox][is_checkbox]"
                ],
			"not-contain": [
					"<label for=\"input_1\""
				]
		    }
	    },
		{
			"type": "special",
			"about": "Checkbox with parameter label",
			"special-page": {
			"page": "FormEdit",
			"query-parameters": "Checkbox with parameter label/01",
			"request-parameters": {}
			},
			"assert-output": {
            "to-contain": [
                    "<label for=\"input_1\"",
					"<input type=\"hidden\" value=\"true\" name=\"standard input[Checkbox][is_checkbox]\"",
					"<input type='checkbox'",
					"name='standard input[Checkbox][value]'",
					"Test1</label>"
                ]
		    }
	    },
		{
			"type": "special",
			"about": "Checkbox re-edit: stored value Yes renders checkbox as checked",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "PFTestCBFormReEdit01/PFTestCBSubjCheckedReEdit01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"<input type='checkbox'",
					"checked='checked'",
					"name='PFTestCBTplReEdit01[PFCBFieldReEdit01][value]'"
				]
			}
		},
		{
			"type": "special",
			"about": "Checkbox re-edit: stored value No renders checkbox as unchecked",
			"special-page": {
				"page": "FormEdit",
				"query-parameters": "PFTestCBFormReEdit01/PFTestCBSubjUncheckedReEdit01",
				"request-parameters": {}
			},
			"assert-output": {
				"to-contain": [
					"<input type='checkbox'",
					"name='PFTestCBTplReEdit01[PFCBFieldReEdit01][value]'"
				],
				"not-contain": [
					"checked='checked'"
				]
			}
		}
	],
	"settings": {
		"wgLang": "en"
	},
	"meta": {
		"version": "2",
		"is-incomplete": false,
		"debug": false
	}
}
